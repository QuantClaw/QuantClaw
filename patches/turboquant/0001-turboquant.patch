@@ -0,0 +1,80 @@
+#pragma once
+
+#include <cstdint>
+#include <string>
+
+#include "ggml-backend.h"
+
+struct ggml_context;
+struct ggml_tensor;
+
+// TurboQuant sidecar binary format (little-endian, all floats are IEEE754 f32):
+//
+//   header (32 bytes):
+//     char     magic[4]      "TQNT"
+//     uint32   version       currently 1
+//     uint32   num_layers    L
+//     uint32   head_dim      D
+//     uint32   num_heads     H
+//     uint32   num_kv_heads  Hkv
+//     uint8    bits_k        1..8
+//     uint8    bits_v        1..8
+//     uint8    _pad[6]       zero
+//
+//   payload: L contiguous per-layer blocks, each of size
+//       (2*D*D + (2^bits_k + 2^bits_v) * D) * sizeof(float)
+//     laid out as:
+//       float hh_k       [D * D]              Householder for K, row-major
+//       float hh_v       [D * D]              Householder for V, row-major
+//       float codebook_k [2^bits_k * D]       K centroids, row-major (row i = centroid i)
+//       float codebook_v [2^bits_v * D]       V centroids, row-major
+//
+// The loader mmaps the payload read-only; accessors below return pointers into it.
+
+struct llama_turboquant_sidecar_meta {
+    uint32_t version      = 0;
+    uint32_t num_layers   = 0;
+    uint32_t head_dim     = 0;
+    uint32_t num_heads    = 0;
+    uint32_t num_kv_heads = 0;
+    uint8_t  bits_k       = 0;
+    uint8_t  bits_v       = 0;
+};
+
+void llama_turboquant_configure(const std::string & sidecar_path, int32_t bits_k, int32_t bits_v);
+
+bool llama_turboquant_is_requested();
+bool llama_turboquant_is_active();
+
+int32_t llama_turboquant_bits_k();
+int32_t llama_turboquant_bits_v();
+
+std::string llama_turboquant_sidecar_path();
+
+bool llama_turboquant_load_sidecar(std::string * error_message = nullptr);
+bool llama_turboquant_get_sidecar_meta(llama_turboquant_sidecar_meta & out_meta);
+
+// Per-layer pointers into the mmap'd payload. Return nullptr if sidecar is not
+// loaded or `il` is out of range. Pointers are stable for the lifetime of the
+// mapping (i.e. until llama_turboquant_configure is called with a new path).
+const float * llama_turboquant_layer_hh_k      (int32_t il);
+const float * llama_turboquant_layer_hh_v      (int32_t il);
+const float * llama_turboquant_layer_codebook_k(int32_t il);
+const float * llama_turboquant_layer_codebook_v(int32_t il);
+
+ggml_tensor * llama_turboquant_prepare_k_write(ggml_context * ctx, ggml_tensor * k_cur, int32_t il);
+ggml_tensor * llama_turboquant_prepare_v_write(ggml_context * ctx, ggml_tensor * v_cur, int32_t il);
+ggml_tensor * llama_turboquant_prepare_k_read (ggml_context * ctx, ggml_tensor * k_view, int32_t il);
+ggml_tensor * llama_turboquant_prepare_v_read (ggml_context * ctx, ggml_tensor * v_view, int32_t il);
+
+// Calibration capture: when set, K/V write-hook tensors are tagged with names
+// "turboquant.k.<il>" / "turboquant.v.<il>", and the eval callback dumps their
+// post-compute contents (raw f32, per-layer append) into <dir> for later
+// Lloyd-Max codebook training.
+void llama_turboquant_set_calibrate_dir(const std::string & dir);
+bool llama_turboquant_is_calibrating();
+
+// Returns the eval callback + user_data for cparams.cb_eval when calibrating.
+// Safe to call unconditionally; returns (nullptr, nullptr) when not calibrating.
+ggml_backend_sched_eval_callback llama_turboquant_calibrate_cb_eval();
+void *                            llama_turboquant_calibrate_cb_user_data();
