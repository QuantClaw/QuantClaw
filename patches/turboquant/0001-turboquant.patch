diff --git a/src/turboquant.cpp b/src/turboquant.cpp
new file mode 100644
index 000000000..a3c1a7344
--- /dev/null
+++ b/src/turboquant.cpp
@@ -0,0 +1,584 @@
+#include "turboquant.h"
+
+#include "llama-impl.h"
+#include "llama-mmap.h"
+
+#include "ggml.h"
+#include "ggml-backend.h"
+
+#include <atomic>
+#include <cstdio>
+#include <cstring>
+#include <filesystem>
+#include <limits>
+#include <memory>
+#include <mutex>
+#include <string>
+#include <unordered_map>
+#include <vector>
+
+namespace {
+
+constexpr size_t TURBOQUANT_HEADER_SIZE = 32;
+constexpr char TURBOQUANT_MAGIC[4] = {'T', 'Q', 'N', 'T'};
+
+struct llama_turboquant_state {
+    std::mutex mu;
+
+    std::string sidecar_path;
+    int32_t bits_k = 8;
+    int32_t bits_v = 8;
+
+    bool loaded = false;
+    std::string loaded_path;
+    llama_turboquant_sidecar_meta meta;
+
+    std::unique_ptr<llama_file> file;
+    std::unique_ptr<llama_mmap> mmap;
+
+    // calibration capture
+    std::string calibrate_dir;
+    std::unordered_map<std::string, FILE *> calibrate_files;
+    std::vector<uint8_t> calibrate_scratch;
+    bool calibrate_dir_created = false;
+};
+
+llama_turboquant_state & turboquant_state() {
+    static llama_turboquant_state state;
+    return state;
+}
+
+std::atomic<bool> g_turboquant_active{false};
+std::atomic<bool> g_turboquant_logged_write{false};
+std::atomic<bool> g_turboquant_logged_read{false};
+
+bool turboquant_valid_bits(int32_t bits) {
+    return bits >= 1 && bits <= 8;
+}
+
+uint32_t read_u32_le(const uint8_t * p) {
+    return (uint32_t(p[0])      ) |
+           (uint32_t(p[1]) <<  8) |
+           (uint32_t(p[2]) << 16) |
+           (uint32_t(p[3]) << 24);
+}
+
+void set_error(std::string * error_message, const std::string & message) {
+    if (error_message) {
+        *error_message = message;
+    }
+}
+
+std::atomic<bool> g_turboquant_calibrating{false};
+std::atomic<bool> g_turboquant_logged_calibrate{false};
+
+// Filename helpers. Format: "<stream>.layer_<il>.f32" under calibrate_dir.
+std::string calibrate_filename(const std::string & dir, char stream, int32_t il) {
+    char buf[64];
+    std::snprintf(buf, sizeof(buf), "%c.layer_%03d.f32", stream, il);
+    return dir + "/" + buf;
+}
+
+// Parse "turboquant.<k|v>.<il>"; return true + fill out params on match.
+bool parse_turboquant_tensor_name(const char * name, char & stream, int32_t & il) {
+    if (name == nullptr) {
+        return false;
+    }
+    constexpr const char prefix[] = "turboquant.";
+    constexpr size_t prefix_len = sizeof(prefix) - 1;
+    if (std::strncmp(name, prefix, prefix_len) != 0) {
+        return false;
+    }
+    const char * rest = name + prefix_len;
+    if (rest[0] != 'k' && rest[0] != 'v') {
+        return false;
+    }
+    if (rest[1] != '.') {
+        return false;
+    }
+    char * end = nullptr;
+    long parsed = std::strtol(rest + 2, &end, 10);
+    if (end == rest + 2 || parsed < 0) {
+        return false;
+    }
+    stream = rest[0];
+    il = int32_t(parsed);
+    return true;
+}
+
+FILE * calibrate_open_file(llama_turboquant_state & state, char stream, int32_t il) {
+    const std::string key = std::string(1, stream) + "." + std::to_string(il);
+
+    auto it = state.calibrate_files.find(key);
+    if (it != state.calibrate_files.end()) {
+        return it->second;
+    }
+
+    if (!state.calibrate_dir_created) {
+        std::error_code ec;
+        std::filesystem::create_directories(state.calibrate_dir, ec);
+        state.calibrate_dir_created = true;
+    }
+
+    const std::string path = calibrate_filename(state.calibrate_dir, stream, il);
+    FILE * f = std::fopen(path.c_str(), "ab");
+    if (f == nullptr) {
+        LLAMA_LOG_WARN("turboquant: failed to open calibration file '%s' (errno=%d)\n",
+                       path.c_str(), errno);
+        return nullptr;
+    }
+    state.calibrate_files.emplace(key, f);
+    return f;
+}
+
+bool turboquant_cb_eval_impl(ggml_tensor * t, bool ask, void * /*user_data*/) {
+    static std::atomic<int> dbg_tensor_count{0};
+    int count = dbg_tensor_count.fetch_add(1, std::memory_order_relaxed);
+    if (count < 80) {
+        LLAMA_LOG_INFO("turboquant_cb_eval: name='%s' ask=%d op=%d\n",
+                       t->name, int(ask), int(t->op));
+    }
+
+    char stream = 0;
+    int32_t il = 0;
+    if (!parse_turboquant_tensor_name(t->name, stream, il)) {
+        return false;
+    }
+
+    if (ask) {
+        return true;
+    }
+
+    if (t->type != GGML_TYPE_F32) {
+        // Only f32 supported for now. Skip silently; the user will notice empty dumps.
+        return false;
+    }
+
+    auto & state = turboquant_state();
+    std::lock_guard<std::mutex> lock(state.mu);
+
+    if (state.calibrate_dir.empty()) {
+        return false;
+    }
+
+    const size_t nbytes = ggml_nbytes(t);
+    state.calibrate_scratch.resize(nbytes);
+    ggml_backend_tensor_get(t, state.calibrate_scratch.data(), 0, nbytes);
+
+    FILE * f = calibrate_open_file(state, stream, il);
+    if (f == nullptr) {
+        return false;
+    }
+
+    const size_t written = std::fwrite(state.calibrate_scratch.data(), 1, nbytes, f);
+    if (written != nbytes) {
+        LLAMA_LOG_WARN("turboquant: short write while dumping calibration tensor '%s' (%zu/%zu)\n",
+                       t->name, written, nbytes);
+    }
+
+    if (!g_turboquant_logged_calibrate.exchange(true, std::memory_order_acq_rel)) {
+        LLAMA_LOG_INFO("turboquant: calibration capture engaged (dir='%s')\n",
+                       state.calibrate_dir.c_str());
+    }
+    return false;  // nothing to keep after collection
+}
+
+} // namespace
+
+void llama_turboquant_configure(const std::string & sidecar_path, int32_t bits_k, int32_t bits_v) {
+    auto & state = turboquant_state();
+    std::lock_guard<std::mutex> lock(state.mu);
+
+    const bool changed =
+        state.sidecar_path != sidecar_path ||
+        state.bits_k != bits_k ||
+        state.bits_v != bits_v;
+
+    state.sidecar_path = sidecar_path;
+    state.bits_k = bits_k;
+    state.bits_v = bits_v;
+
+    if (changed) {
+        state.loaded = false;
+        state.loaded_path.clear();
+        state.meta = {};
+        state.mmap.reset();
+        state.file.reset();
+
+        g_turboquant_active.store(false, std::memory_order_release);
+        g_turboquant_logged_write.store(false, std::memory_order_release);
+        g_turboquant_logged_read.store(false, std::memory_order_release);
+    }
+}
+
+bool llama_turboquant_is_requested() {
+    auto & state = turboquant_state();
+    std::lock_guard<std::mutex> lock(state.mu);
+
+    return !state.sidecar_path.empty();
+}
+
+bool llama_turboquant_is_active() {
+    return g_turboquant_active.load(std::memory_order_acquire);
+}
+
+int32_t llama_turboquant_bits_k() {
+    auto & state = turboquant_state();
+    std::lock_guard<std::mutex> lock(state.mu);
+
+    return state.bits_k;
+}
+
+int32_t llama_turboquant_bits_v() {
+    auto & state = turboquant_state();
+    std::lock_guard<std::mutex> lock(state.mu);
+
+    return state.bits_v;
+}
+
+std::string llama_turboquant_sidecar_path() {
+    auto & state = turboquant_state();
+    std::lock_guard<std::mutex> lock(state.mu);
+
+    return state.sidecar_path;
+}
+
+bool llama_turboquant_load_sidecar(std::string * error_message) {
+    auto & state = turboquant_state();
+    std::lock_guard<std::mutex> lock(state.mu);
+
+    if (state.sidecar_path.empty()) {
+        g_turboquant_active.store(false, std::memory_order_release);
+        return true;
+    }
+
+    if (!turboquant_valid_bits(state.bits_k) || !turboquant_valid_bits(state.bits_v)) {
+        set_error(error_message, "turboquant bits must be in [1, 8]");
+        return false;
+    }
+
+    if (state.loaded && state.loaded_path == state.sidecar_path) {
+        g_turboquant_active.store(true, std::memory_order_release);
+        return true;
+    }
+
+    state.loaded = false;
+    state.loaded_path.clear();
+    state.meta = {};
+    state.mmap.reset();
+    state.file.reset();
+
+    std::unique_ptr<llama_file> file;
+    std::unique_ptr<llama_mmap> mmap;
+
+    try {
+        file = std::make_unique<llama_file>(state.sidecar_path.c_str(), "rb");
+        mmap = std::make_unique<llama_mmap>(file.get());
+    } catch (const std::exception & e) {
+        set_error(error_message, std::string("failed to open turboquant sidecar: ") + e.what());
+        return false;
+    }
+
+    if (!mmap || mmap->size() < TURBOQUANT_HEADER_SIZE) {
+        set_error(error_message, "invalid turboquant sidecar: file is too small");
+        return false;
+    }
+
+    const auto * data = static_cast<const uint8_t *>(mmap->addr());
+    if (data == nullptr) {
+        set_error(error_message, "invalid turboquant sidecar: mmap returned null address");
+        return false;
+    }
+
+    if (std::memcmp(data, TURBOQUANT_MAGIC, sizeof(TURBOQUANT_MAGIC)) != 0) {
+        set_error(error_message, "invalid turboquant sidecar: bad magic (expected TQNT)");
+        return false;
+    }
+
+    llama_turboquant_sidecar_meta meta;
+    meta.version      = read_u32_le(data +  4);
+    meta.num_layers   = read_u32_le(data +  8);
+    meta.head_dim     = read_u32_le(data + 12);
+    meta.num_heads    = read_u32_le(data + 16);
+    meta.num_kv_heads = read_u32_le(data + 20);
+    meta.bits_k       = data[24];
+    meta.bits_v       = data[25];
+
+    if (meta.num_layers == 0 || meta.head_dim == 0) {
+        set_error(error_message, "invalid turboquant sidecar: num_layers/head_dim must be non-zero");
+        return false;
+    }
+
+    if (meta.bits_k != static_cast<uint8_t>(state.bits_k) ||
+        meta.bits_v != static_cast<uint8_t>(state.bits_v)) {
+        set_error(error_message,
+                  "turboquant sidecar bits do not match requested --turboquant-bits-k/--turboquant-bits-v");
+        return false;
+    }
+
+    const uint64_t head_dim = meta.head_dim;
+    const uint64_t layer_values_f32 =
+        2ULL * head_dim * head_dim +
+        ((1ULL << meta.bits_k) + (1ULL << meta.bits_v)) * head_dim;
+
+    if (layer_values_f32 > std::numeric_limits<uint64_t>::max() / 4ULL) {
+        set_error(error_message, "invalid turboquant sidecar: overflow while computing payload size");
+        return false;
+    }
+
+    const uint64_t layer_bytes = layer_values_f32 * 4ULL;
+    const uint64_t payload_bytes = uint64_t(meta.num_layers) * layer_bytes;
+    const uint64_t expected_min_size = uint64_t(TURBOQUANT_HEADER_SIZE) + payload_bytes;
+
+    if (expected_min_size > uint64_t(mmap->size())) {
+        set_error(error_message,
+                  "invalid turboquant sidecar: file smaller than expected payload for declared dimensions");
+        return false;
+    }
+
+    state.file = std::move(file);
+    state.mmap = std::move(mmap);
+    state.meta = meta;
+    state.loaded = true;
+    state.loaded_path = state.sidecar_path;
+
+    g_turboquant_active.store(true, std::memory_order_release);
+
+    LLAMA_LOG_INFO(
+        "turboquant: engaged layers=%u bits_k=%u bits_v=%u\n",
+        state.meta.num_layers,
+        state.meta.bits_k,
+        state.meta.bits_v);
+
+    LLAMA_LOG_INFO(
+        "%s: loaded sidecar '%s' (v%u, layers=%u, head_dim=%u, heads=%u, kv_heads=%u, bits_k=%u, bits_v=%u)\n",
+        __func__,
+        state.loaded_path.c_str(),
+        state.meta.version,
+        state.meta.num_layers,
+        state.meta.head_dim,
+        state.meta.num_heads,
+        state.meta.num_kv_heads,
+        state.meta.bits_k,
+        state.meta.bits_v);
+
+    return true;
+}
+
+bool llama_turboquant_get_sidecar_meta(llama_turboquant_sidecar_meta & out_meta) {
+    auto & state = turboquant_state();
+    std::lock_guard<std::mutex> lock(state.mu);
+
+    if (!state.loaded) {
+        return false;
+    }
+
+    out_meta = state.meta;
+    return true;
+}
+
+namespace {
+
+const float * turboquant_layer_region(int32_t il, uint64_t region_offset_f32) {
+    auto & state = turboquant_state();
+    std::lock_guard<std::mutex> lock(state.mu);
+
+    if (!state.loaded || state.mmap == nullptr) {
+        return nullptr;
+    }
+    if (il < 0 || uint32_t(il) >= state.meta.num_layers) {
+        return nullptr;
+    }
+
+    const uint64_t D = state.meta.head_dim;
+    const uint64_t K = 1ULL << state.meta.bits_k;
+    const uint64_t V = 1ULL << state.meta.bits_v;
+    const uint64_t per_layer_f32 = 2ULL * D * D + (K + V) * D;
+
+    const uint8_t * base    = static_cast<const uint8_t *>(state.mmap->addr());
+    const uint64_t  byte_ofs = uint64_t(TURBOQUANT_HEADER_SIZE)
+                             + uint64_t(il) * per_layer_f32 * sizeof(float)
+                             + region_offset_f32 * sizeof(float);
+
+    return reinterpret_cast<const float *>(base + byte_ofs);
+}
+
+} // namespace
+
+const float * llama_turboquant_layer_hh_k(int32_t il) {
+    return turboquant_layer_region(il, 0);
+}
+
+const float * llama_turboquant_layer_hh_v(int32_t il) {
+    auto & state = turboquant_state();
+    uint64_t D = 0;
+    {
+        std::lock_guard<std::mutex> lock(state.mu);
+        if (!state.loaded) {
+            return nullptr;
+        }
+        D = state.meta.head_dim;
+    }
+    return turboquant_layer_region(il, D * D);
+}
+
+const float * llama_turboquant_layer_codebook_k(int32_t il) {
+    auto & state = turboquant_state();
+    uint64_t D = 0;
+    {
+        std::lock_guard<std::mutex> lock(state.mu);
+        if (!state.loaded) {
+            return nullptr;
+        }
+        D = state.meta.head_dim;
+    }
+    return turboquant_layer_region(il, 2ULL * D * D);
+}
+
+const float * llama_turboquant_layer_codebook_v(int32_t il) {
+    auto & state = turboquant_state();
+    uint64_t D = 0;
+    uint64_t K = 0;
+    {
+        std::lock_guard<std::mutex> lock(state.mu);
+        if (!state.loaded) {
+            return nullptr;
+        }
+        D = state.meta.head_dim;
+        K = 1ULL << state.meta.bits_k;
+    }
+    return turboquant_layer_region(il, 2ULL * D * D + K * D);
+}
+
+ggml_tensor * llama_turboquant_prepare_k_write(ggml_context * ctx, ggml_tensor * k_cur, int32_t il) {
+    (void) ctx;
+
+    if (!llama_turboquant_is_active()) {
+        return k_cur;
+    }
+
+    if (!g_turboquant_logged_write.exchange(true, std::memory_order_acq_rel)) {
+        LLAMA_LOG_INFO(
+            "%s: TurboQuant write hooks enabled (bits_k=%d, bits_v=%d)\n",
+            __func__,
+            llama_turboquant_bits_k(),
+            llama_turboquant_bits_v());
+    }
+
+    if (llama_turboquant_is_calibrating()) {
+        ggml_tensor * tap = ggml_cont(ctx, k_cur);
+        char name[32];
+        std::snprintf(name, sizeof(name), "turboquant.k.%d", int(il));
+        ggml_set_name(tap, name);
+        ggml_set_output(tap);
+        return tap;
+    }
+
+    // Scaffolding hook: currently pass-through.
+    // Real quantization will replace this with Householder+Lloyd-Max encode.
+    return k_cur;
+}
+
+ggml_tensor * llama_turboquant_prepare_v_write(ggml_context * ctx, ggml_tensor * v_cur, int32_t il) {
+    (void) ctx;
+
+    if (!llama_turboquant_is_active()) {
+        return v_cur;
+    }
+
+    if (!g_turboquant_logged_write.exchange(true, std::memory_order_acq_rel)) {
+        LLAMA_LOG_INFO(
+            "%s: TurboQuant write hooks enabled (bits_k=%d, bits_v=%d)\n",
+            __func__,
+            llama_turboquant_bits_k(),
+            llama_turboquant_bits_v());
+    }
+
+    if (llama_turboquant_is_calibrating()) {
+        ggml_tensor * tap = ggml_cont(ctx, v_cur);
+        char name[32];
+        std::snprintf(name, sizeof(name), "turboquant.v.%d", int(il));
+        ggml_set_name(tap, name);
+        ggml_set_output(tap);
+        return tap;
+    }
+
+    // Scaffolding hook: currently pass-through.
+    return v_cur;
+}
+
+ggml_tensor * llama_turboquant_prepare_k_read(ggml_context * ctx, ggml_tensor * k_view, int32_t il) {
+    (void) ctx;
+    (void) il;
+
+    if (!llama_turboquant_is_active()) {
+        return k_view;
+    }
+
+    if (!g_turboquant_logged_read.exchange(true, std::memory_order_acq_rel)) {
+        LLAMA_LOG_INFO(
+            "%s: TurboQuant read hooks enabled (bits_k=%d, bits_v=%d)\n",
+            __func__,
+            llama_turboquant_bits_k(),
+            llama_turboquant_bits_v());
+    }
+
+    // Scaffolding hook: currently pass-through.
+    // Real reconstruction will decode cached indices/centroids here.
+    return k_view;
+}
+
+ggml_tensor * llama_turboquant_prepare_v_read(ggml_context * ctx, ggml_tensor * v_view, int32_t il) {
+    (void) ctx;
+    (void) il;
+
+    if (!llama_turboquant_is_active()) {
+        return v_view;
+    }
+
+    if (!g_turboquant_logged_read.exchange(true, std::memory_order_acq_rel)) {
+        LLAMA_LOG_INFO(
+            "%s: TurboQuant read hooks enabled (bits_k=%d, bits_v=%d)\n",
+            __func__,
+            llama_turboquant_bits_k(),
+            llama_turboquant_bits_v());
+    }
+
+    // Scaffolding hook: currently pass-through.
+    return v_view;
+}
+
+void llama_turboquant_set_calibrate_dir(const std::string & dir) {
+    auto & state = turboquant_state();
+    std::lock_guard<std::mutex> lock(state.mu);
+
+    // Close existing files when the dir changes (or is cleared).
+    if (state.calibrate_dir != dir) {
+        for (auto & kv : state.calibrate_files) {
+            if (kv.second != nullptr) {
+                std::fclose(kv.second);
+            }
+        }
+        state.calibrate_files.clear();
+        state.calibrate_dir_created = false;
+    }
+
+    state.calibrate_dir = dir;
+    g_turboquant_calibrating.store(!dir.empty(), std::memory_order_release);
+    g_turboquant_logged_calibrate.store(false, std::memory_order_release);
+}
+
+bool llama_turboquant_is_calibrating() {
+    return g_turboquant_calibrating.load(std::memory_order_acquire);
+}
+
+ggml_backend_sched_eval_callback llama_turboquant_calibrate_cb_eval() {
+    if (!llama_turboquant_is_calibrating()) {
+        return nullptr;
+    }
+    return turboquant_cb_eval_impl;
+}
+
+void * llama_turboquant_calibrate_cb_user_data() {
+    return nullptr;
+}
